POSTGRES_HOST=xxxx
POSTGRES_PORT=xxxx
POSTGRES_USER=xxxx
POSTGRES_PASSWORD=xxxx
POSTGRES_DB=xxxx

SMTP_HOST=xxxx
SMTP_PORT=xxxx
SMTP_USER=xxxx
SMTP_PASSWORD=xxxx
SMTP_FROM=xxxx
SMTP_FROM_NAME=xxxx

SERVER_PORT=8080
UDP_PORT=9000

R2_ACCESS_KEY_ID=xxxx
R2_SECRET_ACCESS_KEY=xxxx
R2_BUCKET_NAME=xxxx
R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://<your-domain-or-pub-hash>.r2.dev

# Comma-separated list of checks for "make all-checks" (Makefile only, not read by Go).
#   db, mail, verify  — pick which to run. Empty = run all three.
#   Example: CHECKS=db,verify
CHECKS=verify

MAIL_TEST_TO=xxxx

# Email verifier method — how strictly to validate emails before registration.
# "default" : syntax + MX record + disposable + role checks (no SMTP, works on any network)
# "smtp"    : full SMTP mailbox verification on port 25 (requires port 25 to be open)
# "off"     : skip email verification entirely
EMAIL_VERIFIER_METHOD=default

# Rate limiting for auth endpoints (failed attempts before soft lock).
RATE_LIMIT_MAX_ATTEMPTS=5
RATE_LIMIT_WINDOW=15m
RATE_LIMIT_LOCK_DURATION=30m

# ── Main URL of the server (used for email links, redirects, etc.) ──
BASE_URL=http://localhost:8080